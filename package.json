{
  "name": "bun-sqlx",
  "version": "0.7.0",
  "description": "Compile-time-checked raw SQL for Bun + PostgreSQL. Inspired by sqlx.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "bin": {
    "bun-sqlx": "./bin/bun-sqlx.ts"
  },
  "files": [
    "src",
    "bin",
    "dist",
    "README.md",
    "ROADMAP.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ONREZA/bun-sqlx.git"
  },
  "homepage": "https://github.com/ONREZA/bun-sqlx#readme",
  "bugs": {
    "url": "https://github.com/ONREZA/bun-sqlx/issues"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "keywords": [
    "bun",
    "postgres",
    "postgresql",
    "sql",
    "sqlx",
    "typescript",
    "type-safe",
    "migrations"
  ],
  "scripts": {
    "prepare": "[ -d .git ] && lefthook install >/dev/null 2>&1 || true",
    "test": "bun test tests",
    "test:typecheck": "tsc --noEmit",
    "test:example": "bunx tsc -p example --noEmit",
    "sqlx:prepare": "bun bin/bun-sqlx.ts prepare",
    "sqlx:migrate": "bun bin/bun-sqlx.ts migrate",
    "build": "rm -rf dist && tsc -p tsconfig.build.json"
  },
  "peerDependencies": {
    "typescript": ">=5.4"
  },
  "dependencies": {
    "libpg-query": "^17.7.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bun": "latest",
    "lefthook": "^2.1.6",
    "testcontainers": "^11.14.0",
    "typescript": "^5.6.0"
  }
}
