{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "types": ["bun"],
    "baseUrl": ".",
    "paths": {
      "@onreza/sqlx-js": ["../src/index.ts"]
    }
  },
  "include": ["app.ts", "v*.ts", "json-types.d.ts", "sqlx-js-env.d.ts"]
}
